---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  credit?: string | null;
  width?: number;
  height?: number;
  class?: string;
  loading?: 'lazy' | 'eager';
}

const {
  src,
  alt,
  credit,
  width,
  height,
  class: className,
  loading,
} = Astro.props;
---

<div class:list={['credited-image', className]}>
  <Image {src} {alt} {width} {height} {loading} />
  {credit && <span class="image-credit">{credit}</span>}
</div>

<style>
  .credited-image {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }

  .image-credit {
    font-size: 0.7rem;
    letter-spacing: 0.02em;
    color: var(--color-gray-700, #555);
    text-align: center;
    line-height: 1.2;
  }

  .image-credit::before {
    content: '© ';
  }
</style>
