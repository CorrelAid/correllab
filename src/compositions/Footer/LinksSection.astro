---
interface Props {
  section: {
    title: string;
    titleUrl?: string;
    links: Array<{ href: string; label: string }>;
  };
}

const { section } = Astro.props;
const { title, titleUrl, links } = section;
---

<small class="links-section">
  <h5>
    {titleUrl ? <a href={titleUrl}>{title}</a> : title}
  </h5>
  <ul>
    {
      links.map((link) => (
        <li>
          <a href={link.href}>{link.label}</a>
        </li>
      ))
    }
  </ul>
</small>

<style>
  .links-section {
    --gap: 8px;

    text-wrap: balance;
    display: flex;
    flex-direction: column;
    gap: var(--gap);
    line-height: 1;
    padding: var(--block-padding, 0);
    border-radius: var(--block-padding, 0);

    & h5 {
      font-family: var(--font-family-accent);
      font-size: 16px;
      font-weight: var(--font-weight-normal);
      line-height: 1;
      color: var(--color-gray-muted);

      & a {
        color: inherit;
        text-decoration: none;

        &:hover {
          text-decoration: underline;
        }
      }
    }

    & ul {
      display: flex;
      flex-direction: column;
      gap: 8px;
      list-style: none;
      padding: 0;
      margin: 0;

      & li {
        margin: 0;
        line-height: 1;
      }
    }
  }
</style>
