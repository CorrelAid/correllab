---
import { getImage } from 'astro:assets';

import Blockquote from '@/components/Blockquote.astro';
import CardPlain from '@components/cards/CardPlain.astro';
import LabLinkButton from '@components/LabLinkButton.astro';
import BackgroundSection from '@components/sections/BackgroundSection.astro';
import ColumnsSection from '@components/sections/ColumnsSection.astro';
import PeopleSection from '@compositions/People.astro';
import KursLayout from '@layouts/KursLayout.astro';

import carouselBackgroundSvg from '@assets/branding/agentur/CL-Zitat-BackgroundGradient-.svg';
const CarouselBackground = await getImage({
  src: carouselBackgroundSvg,
  format: 'webp',
});

import phasen from '@data/phasen.json';
import { quotes } from '@data/quotes.js';
import { people } from '@data/people';

import * as KursColumns1 from '@content/kurse/deepdive_ki_columns_1.md';
import * as KursColumns2 from '@content/kurse/deepdive_ki_columns_2.md';
import * as KursSchedule from '@content/kurse/deepdive_ki_schedule.md';
import * as KostenContent from '@content/kurse/deepdive_ki_kosten.md';
---

<KursLayout title="CorrelLAB: Deep Dive Künstliche Intelligenz">
  <Fragment slot="subtitle">
    Deep Dive<br />&ndash;&nbsp;<strong>Künstliche Intelligenz</strong>
  </Fragment>
  <p slot="teaser">
    Du willst Künstliche Intelligenz für deine Zwecke einsetzen, aber du weißt nicht wie? Wir
    helfen dir, in KI-Themen durchzublicken und die richtige KI-Lösung für dein Problem
    auszuwählen!
  </p>
  <Fragment slot="cta">
    <LabLinkButton href="#start">Kursüberblick</LabLinkButton>
    <LabLinkButton href="/kurse/abo/">CorrelLAB Bildungsabo</LabLinkButton>
  </Fragment>

  <ColumnsSection center_title>
    <Fragment slot="pre">
      <Blockquote bare wide>
        Künstliche Intelligenz bietet enorme Chancen, aber wie kannst du sie für deine
        Non-Profit-Arbeit nutzen?<br /><br />
        In diesem Kurs lernst du, wie du KI-Tools praktisch, effizient und verantwortungsvoll in
        deiner Non-Profit-Arbeit einsetzt. Dabei geht es um konkrete Anwendungsmöglichkeiten,
        technische Lösungsansätze und darum, KI-Nutzung orientiert an den Werten der Organisation
        auszurichten.<br /><br />
        Wir steigen gemeinsam ein, ohne Vorkenntnisse vorauszusetzen, und arbeiten mit
        Praxisbeispielen aus der Zivilgesellschaft. So bekommst du nicht nur einen klaren
        Durchblick über technische Hintergründe, sondern auch über rechtliche und ethische
        Rahmenbedingungen.
      </Blockquote>
    </Fragment>
    <div class="flex rows gap-2" slot="col1">
      <h4>Der Kurs ist für dich, wenn…</h4>
      <Fragment set:html={await KursColumns1.compiledContent()} />
    </div>

    <div class="flex rows gap-2" slot="col2">
      <h4>Im Kurs lernst du…</h4>
      <Fragment set:html={await KursColumns2.compiledContent()} />
    </div>
  </ColumnsSection>

  <BackgroundSection
    options={{ content_grid: true, center: true }}
    asset={{ src: CarouselBackground.src, position: 'bottom right' }}
  >
    {
      quotes.deepdive_ki.map((quote, index) => (
        <Blockquote
          id={index + 1}
          image={quote.image}
          imageAlt={quote.cite.name}
          imageCredit={quote.credit}
        >
          <Fragment>{quote.quote}</Fragment>
          <Fragment slot="cite">
            {' '}
            <span class="name txt-italic">{quote.cite.name}</span>
            <span class="role">{quote.cite.role}</span>
          </Fragment>
        </Blockquote>
      ))
    }
  </BackgroundSection>

  <section class="prose">
    <CardPlain>
      <Fragment slot="content">
        <h4 class="kurs-heading">Die Eckdaten</h4>
        <Fragment
          set:html={await KursSchedule.compiledContent().then((content) =>
            content.replace('{period}', phasen.kurse.meta.deepdive_ki.period)
          )}
        />
        <p class="eckdaten-note">
          Am ersten Tag erkunden wir die vielfältigen Einsatzmöglichkeiten von KI. Am zweiten Tag
          vertiefen wir uns in Generative KI und geben einen Ausblick darauf, wie du KI-Lösungen
          maßgeschneidert und wertegeleitet für deine Zwecke einsetzen kannst. Im interaktiven
          Online-Format profitierst du vom Austausch mit anderen Teilnehmenden, die ähnliche
          Herausforderungen wie du meistern.
        </p>
      </Fragment>
    </CardPlain>
  </section>

  <section class="pt-0">
    <div class="prose">
      <Fragment set:html={await KostenContent.compiledContent()} />
    </div>
  </section>

  <section class="sticky sticky-bottom">
    <LabLinkButton href="https://pretix.eu/correlaid/deepdive-ki/">
      Hier geht es zur Anmeldung!
    </LabLinkButton>
  </section>

  <PeopleSection title="Fragen? Melde dich bei uns!" people={[people.zoe, people.nora]} />

  <div class="flex cols center gap-2 pad-8 wrap" slot="footer-links">
    <LabLinkButton href="/kurse/abo/">CorrelLAB Bildungsabo</LabLinkButton>
    <LabLinkButton href="/">Zur Startseite</LabLinkButton>
  </div>
</KursLayout>

<style>
  .kurs-heading {
    margin: 0;
    color: var(--color-grey-900);
    font-weight: var(--font-weight-bold);
  }

</style>
