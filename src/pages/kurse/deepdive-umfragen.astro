---
import { getImage } from 'astro:assets';

import Blockquote from '@/components/Blockquote.astro';
import CardPlain from '@components/cards/CardPlain.astro';
import LabLinkButton from '@components/LabLinkButton.astro';
import ColumnsSection from '@components/sections/ColumnsSection.astro';
import PeopleSection from '@compositions/People.astro';
import KursLayout from '@layouts/KursLayout.astro';

import carouselBackgroundSvg from '@assets/branding/agentur/CL-Zitat-BackgroundGradient-.svg';
const CarouselBackground = await getImage({
  src: carouselBackgroundSvg,
  format: 'webp',
});

import phasen from '@data/phasen.json';
import { people } from '@data/people';

import * as KursColumns1 from '@content/kurse/deepdive_umfragen_columns_1.md';
import * as KursColumns2 from '@content/kurse/deepdive_umfragen_columns_2.md';
import * as KursSchedule from '@content/kurse/deepdive_umfragen_schedule.md';
import * as KostenContent from '@content/kurse/deepdive_umfragen_kosten.md';
---

<KursLayout title="CorrelLAB: Deep Dive Umfragen">
  <Fragment slot="subtitle">
    Deep Dive<br />&ndash;&nbsp;<strong>Umfragen richtig konzipieren und durchführen</strong>
  </Fragment>
  <p slot="teaser">
    Interessiert an eurer Wirkung, euren Zielgruppen und Ehrenamtlichen? Wir helfen dir, deine
    Umfragen zu planen und durchzuführen!
  </p>
  <Fragment slot="cta">
    <LabLinkButton href="#start">Kursüberblick</LabLinkButton>
    <LabLinkButton href="/kurse/abo/">CorrelLAB Bildungs-Abo</LabLinkButton>
  </Fragment>

  <ColumnsSection center_title>
    <Fragment slot="pre">
      <Blockquote bare wide>
        Umfragen helfen dabei, eure Zielgruppen und Ehrenamtlichen besser zu verstehen, eure
        Projekte zu evaluieren und Feedback zu sammeln.<br /><br />
        Aber welche Fragen sind wirklich sinnvoll? Wie vermeidet man missverständliche
        Formulierungen? Wie lassen sich Datenschutzrichtlinien einhalten? Und über welche Kanäle und
        Tools bekommt man die meisten Antworten? Wir helfen dir, deine Umfragen richtig und
        selbstbewusst zu konzipieren!
      </Blockquote>
    </Fragment>
    <div class="flex rows gap-2" slot="col1">
      <h4>Der Deep Dive ist für dich, wenn…</h4>
      <Fragment set:html={await KursColumns1.compiledContent()} />
    </div>

    <div class="flex rows gap-2" slot="col2">
      <h4>Im Deep Dive lernst du…</h4>
      <Fragment set:html={await KursColumns2.compiledContent()} />
    </div>
  </ColumnsSection>

  <section class="prose pt-0">
    <CardPlain>
      <Fragment slot="content">
        <h4 class="kurs-heading">Die Eckdaten</h4>
        <Fragment
          set:html={await KursSchedule.compiledContent().then((content) =>
            content.replace('{period}', phasen.kurse.meta.deepdive_umfragen.period)
          )}
        />
      </Fragment>
    </CardPlain>
  </section>

  <section class="pt-0">
    <div class="prose">
      <Fragment set:html={await KostenContent.compiledContent()} />
    </div>
  </section>

  <section class="sticky sticky-bottom">
    <LabLinkButton href="https://pretix.eu/correlaid/deepdive-umfragen/">
      Hier geht es zur Anmeldung!
    </LabLinkButton>
  </section>

  <PeopleSection title="Fragen? Melde dich bei uns!" people={[people.zoe, people.nora]} />

  <div class="flex cols center gap-2 pad-8 wrap" slot="footer-links">
    <LabLinkButton href="/kurse/abo/">CorrelLAB Bildungs-Abo</LabLinkButton>
    <LabLinkButton href="/">Zur Startseite</LabLinkButton>
  </div>
</KursLayout>

<style>
  .kurs-heading {
    margin: 0;
    color: var(--color-grey-900);
    font-weight: var(--font-weight-bold);
  }
</style>
