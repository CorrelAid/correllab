---
import { getImage } from 'astro:assets';

import Blockquote from '@/components/Blockquote.astro';
import CardPlain from '@components/cards/CardPlain.astro';
import LabLinkButton from '@components/LabLinkButton.astro';
import BackgroundSection from '@components/sections/BackgroundSection.astro';
import ColumnsSection from '@components/sections/ColumnsSection.astro';
import PeopleSection from '@compositions/People.astro';
import KursLayout from '@layouts/KursLayout.astro';

import carouselBackgroundSvg from '@assets/branding/agentur/CL-Zitat-BackgroundGradient-.svg';
const CarouselBackground = await getImage({
  src: carouselBackgroundSvg,
  format: 'webp',
});

import phasen from '@data/phasen.json';
import { quotes } from '@data/quotes.js';
import { people } from '@data/people';

import * as KursColumns1 from '@content/kurse/fokuskurs_kommunizieren_columns_1.md';
import * as KursColumns2 from '@content/kurse/fokuskurs_kommunizieren_columns_2.md';
import * as KursSchedule from '@content/kurse/fokuskurs_kommunizieren_schedule.md';
import * as KostenContent from '@content/kurse/fokuskurs_kommunizieren_kosten.md';
---

<KursLayout title="CorrelLAB: Fokuskurs Kommunizieren mit Daten">
  <Fragment slot="subtitle">
    Fokuskurs<br />&ndash;&nbsp;<strong>Kommunizieren mit Daten</strong>
  </Fragment>
  <p slot="teaser">
    Du siehst tolle Diagramme bei anderen Organisationen und denkst: „So etwas bräuchten wir
    auch!“, aber weißt nicht wie? Wir helfen dir, mit Daten-Geschichten sichtbar zu machen, was
    deine Arbeit bewirkt.
  </p>
  <Fragment slot="cta">
    <LabLinkButton href="#start">Kursüberblick</LabLinkButton>
    <LabLinkButton href="/kurse/abo/">CorrelLAB Bildungs-Abo</LabLinkButton>
  </Fragment>

  <ColumnsSection center_title>
    <Fragment slot="pre">
      <Blockquote bare wide>
        Daten können Geschichten erzählen, … wenn man weiß, wie! In diesem Kurs lernst du, wie du
        anschauliche Visualisierungen und überzeugende Daten-Geschichten erstellst. Dabei geht es
        um die Auswahl passender Diagrammtypen, die Gestaltung von Grafiken nach
        Wahrnehmungsprinzipien und die Aufbereitung von Informationen für verschiedene
        Zielgruppen.<br /><br />
        Grundlegende Erfahrungen im Umgang mit Daten oder erste Berührungspunkte mit
        Wirkungsmanagement sind hilfreich, spezielle Vorkenntnisse zur Visualisierung brauchst du
        aber nicht; wir steigen gemeinsam Schritt für Schritt anhand von Praxisbeispielen aus der
        Zivilgesellschaft ein. Dabei profitierst du vom Austausch mit den anderen
        Kursteilnehmenden.
      </Blockquote>
    </Fragment>
    <div class="flex rows gap-2" slot="col1">
      <h4>Der Kurs ist für dich, wenn…</h4>
      <Fragment set:html={await KursColumns1.compiledContent()} />
    </div>

    <div class="flex rows gap-2" slot="col2">
      <h4>Im Kurs lernst du…</h4>
      <Fragment set:html={await KursColumns2.compiledContent()} />
    </div>
  </ColumnsSection>

  <BackgroundSection
    options={{ content_grid: true, center: true }}
    asset={{ src: CarouselBackground.src, position: 'bottom right' }}
  >
    {
      quotes.fokuskurs_kommunizieren.map((quote, index) => (
        <Blockquote
          id={index + 1}
          image={quote.image}
          imageAlt={quote.cite.name}
          imageCredit={quote.credit}
        >
          <Fragment>{quote.quote}</Fragment>
          <Fragment slot="cite">
            {' '}
            <span class="name txt-italic">{quote.cite.name}</span>
            <span class="role">{quote.cite.role}</span>
          </Fragment>
        </Blockquote>
      ))
    }
  </BackgroundSection>

  <section class="prose">
    <CardPlain>
      <Fragment slot="content">
        <h4 class="kurs-heading">Die Eckdaten</h4>
        <Fragment
          set:html={await KursSchedule.compiledContent().then((content) =>
            content.replace('{period}', phasen.kurse.meta.fokuskurs_kommunizieren.period)
          )}
        />
        <p class="cooperation-note">
          Der Kurs ist eine Kooperation von <a href="https://correlaid.org">CorrelAid</a> und der <a
            href="https://initiative-wirkungsmanagement.de/">Initiative Wirkungsmanagement</a>.
          Gemeinsam bringen wir Datenkompetenz und Wirkungsorientierung zusammen, um Organisationen
          in der Zivilgesellschaft praxisnah zu unterstützen.
        </p>
      </Fragment>
    </CardPlain>
  </section>

  <section class="pt-0">
    <div class="prose">
      <Fragment set:html={await KostenContent.compiledContent()} />
    </div>
  </section>

  <section class="sticky sticky-bottom">
    <LabLinkButton href="https://pretix.eu/correlaid/fokuskurs-ds/">
      Hier geht es zur Anmeldung!
    </LabLinkButton>
  </section>

  <PeopleSection title="Fragen? Melde dich bei uns!" people={[people.zoe, people.nora]} />

  <div class="flex cols center gap-2 pad-8 wrap" slot="footer-links">
    <LabLinkButton href="/kurse/abo/">CorrelLAB Bildungs-Abo</LabLinkButton>
    <LabLinkButton href="/">Zur Startseite</LabLinkButton>
  </div>
</KursLayout>

<style>
  .kurs-heading {
    margin: 0;
    color: var(--color-grey-900);
    font-weight: var(--font-weight-bold);
  }

  .cooperation-note {
    font-size: var(--font-size-sm);
  }
</style>
