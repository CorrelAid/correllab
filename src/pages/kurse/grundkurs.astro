---
import { getImage } from 'astro:assets';

import Blockquote from '@/components/Blockquote.astro';
import CardPlain from '@components/cards/CardPlain.astro';
import LabLinkButton from '@components/LabLinkButton.astro';
import BackgroundSection from '@components/sections/BackgroundSection.astro';
import ColumnsSection from '@components/sections/ColumnsSection.astro';
import Banner from '@compositions/Banner.astro';
import PeopleSection from '@compositions/People.astro';
import KursLayout from '@layouts/KursLayout.astro';

import carouselBackgroundSvg from '@assets/branding/agentur/CL-Zitat-BackgroundGradient-.svg';
const CarouselBackground = await getImage({
  src: carouselBackgroundSvg,
  format: 'webp',
});

import phasen from '@data/phasen.json';
import { quotes } from '@data/quotes.js';
import { people } from '@data/people';

import * as KursColumns1 from '@content/kurse/grundkurs_columns_1.md';
import * as KursColumns2 from '@content/kurse/grundkurs_columns_2.md';
import * as KursSchedule from '@content/kurse/grundkurs_schedule.md';
import * as KostenContent from '@content/kurse/grundkurs_kosten.md';
---

<KursLayout title="CorrelLAB: Grundkurs">
  <Fragment slot="subtitle">
    CorrelLAB Grundkurs<br />&ndash;&nbsp;<strong>Wie können Daten deine Probleme lösen?</strong>
  </Fragment>
  <p slot="teaser">
    Daten helfen erst, wenn man sie richtig nutzt. Aber wie startest du? Welche Tools sind gut für
    den Anfang?
  </p>
  <Fragment slot="cta">
    <LabLinkButton href="#start">Kursüberblick</LabLinkButton>
    <LabLinkButton href="/kurse/abo/">CorrelLAB Bildungs-Abo</LabLinkButton>
  </Fragment>

  <ColumnsSection center_title>
    <Fragment slot="pre">
      <Blockquote bare wide>
        Wer richtig mit Daten arbeitet, erzielt mehr Wirkung bei weniger Aufwand. Aber was bedeutet
        dieses „richtig“? In diesem Grundkurs lernst du, wie du das Potential von Daten für dich
        nutzbar machen kannst.<br /><br />
        Dabei geht es um die Erhebung, das Management, die Bereinigung, Analyse oder Kommunikation
        von Daten, aber auch um Themengebiete wie Künstliche Intelligenz (KI) und Datenschutz.<br
        /><br />
        Alle Themen werden mit Beispielen aus dem zivilgesellschaftlichen Kontext illustriert und mit
        praktischen Übungen werden Tools und Erlerntes sofort angewendet.
      </Blockquote>
    </Fragment>
    <div class="flex rows gap-2" slot="col1">
      <h4>Der Kurs ist für dich, wenn…</h4>
      <Fragment set:html={await KursColumns1.compiledContent()} />
    </div>

    <div class="flex rows gap-2" slot="col2">
      <h4>Im Kurs lernst du…</h4>
      <Fragment set:html={await KursColumns2.compiledContent()} />
    </div>
  </ColumnsSection>

  <BackgroundSection
    options={{ content_grid: true, center: true }}
    asset={{ src: CarouselBackground.src, position: 'bottom right' }}
  >
    {
      quotes.grundkurs.map((quote, index) => (
        <Blockquote
          id={index + 1}
          image={quote.image}
          imageAlt={quote.cite.name}
          imageCredit={quote.credit}
        >
          <Fragment>{quote.quote}</Fragment>
          <Fragment slot="cite">
            {' '}
            <span class="name txt-italic">{quote.cite.name}</span>
            <span class="role">{quote.cite.role}</span>
          </Fragment>
        </Blockquote>
      ))
    }
  </BackgroundSection>

  <section class="prose">
    <CardPlain>
      <Fragment slot="content">
        
        <h4 class="kurs-heading">Wie läuft der Kurs ab?</h4>
        <Fragment
          set:html={await KursSchedule.compiledContent().then((content) =>
            content.replace('{period}', phasen.kurse.meta.grundkurs.period)
          )}
        />
      <h4 class="kurs-heading">Die Themen</h4>
        <ul class="topics-list">
          {phasen.kurse.meta.grundkurs.topics.map((topic) => <li>{topic}</li>)}
        </ul>
      </Fragment>
    </CardPlain>
  </section>

  <section class="pt-0">
    <div class="prose">
      <Fragment set:html={await KostenContent.compiledContent()} />
    </div>
  </section>

  <section class="sticky sticky-bottom">
    <LabLinkButton href="https://pretix.eu/correlaid/correllab-gk/">
      Hier geht es zur Anmeldung!
    </LabLinkButton>
  </section>

  <PeopleSection title="Fragen? Melde dich bei uns!" people={[people.zoe, people.nora]} />

  <div class="flex cols center gap-2 pad-8 wrap" slot="footer-links">
    <LabLinkButton href="/kurse/abo/">CorrelLAB Bildungs-Abo</LabLinkButton>
    <LabLinkButton href="/praxisphase/">Zur Praxisphase</LabLinkButton>
  </div>
</KursLayout>

<style>
  .topics-list {
    columns: 2;
    column-gap: 2rem;
  }

  .topics-list :global(li) {
    break-inside: avoid;
  }

  .kurs-heading {
    margin: 0;
    color: var(--color-grey-900);
    font-weight: var(--font-weight-bold);
  }

  @media (max-width: 600px) {
    .topics-list {
      columns: 1;
    }
  }
</style>
