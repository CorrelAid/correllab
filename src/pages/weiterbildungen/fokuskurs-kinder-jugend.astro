---
import { getImage } from 'astro:assets';

import Blockquote from '@/components/Blockquote.astro';
import CardPlain from '@components/cards/CardPlain.astro';
import LabLinkButton from '@components/LabLinkButton.astro';
import ColumnsSection from '@components/sections/ColumnsSection.astro';
import PeopleSection from '@compositions/People.astro';
import KursLayout from '@layouts/KursLayout.astro';

import carouselBackgroundSvg from '@assets/branding/agentur/CL-Zitat-BackgroundGradient-.svg';
const CarouselBackground = await getImage({
  src: carouselBackgroundSvg,
  format: 'webp',
});

import phasen from '@data/phasen.json';
import { people } from '@data/people';

import * as KursColumns1 from '@content/kurse/fokuskurs_kinder_jugend_columns_1.md';
import * as KursColumns2 from '@content/kurse/fokuskurs_kinder_jugend_columns_2.md';
import * as KursSchedule from '@content/kurse/fokuskurs_kinder_jugend_schedule.md';
import * as KostenContent from '@content/kurse/fokuskurs_kinder_jugend_kosten.md';
---

<KursLayout title="CorrelLAB: Fokuskurs Datenerhebung mit Kindern und Jugendlichen">
  <Fragment slot="subtitle">
    Fokuskurs<br />&ndash;&nbsp;<strong>Datenerhebung mit Kindern und Jugendlichen</strong>
  </Fragment>
  <p slot="teaser">
    Endlich verstehen, wie du Daten bei jungen Zielgruppen erhebst – methodisch durchdacht und
    wirklich passend zur Altersgruppe.
  </p>
  <Fragment slot="cta">
    <LabLinkButton href="#start">Kursüberblick</LabLinkButton>
    <LabLinkButton href="/weiterbildungen">CorrelLAB-Weiterbildungen</LabLinkButton>
  </Fragment>

  <ColumnsSection center_title>
    <Fragment slot="pre">
      <Blockquote bare wide>
        Du willst endlich verstehen, wie du Daten bei Kindern und Jugendlichen methodisch durchdacht
        und wirklich passend zur Zielgruppe erhebst? Ob du Wirkung messen, Bedarfe erfassen oder
        Angebote evaluieren möchtest: Dieser Fokuskurs holt dich da ab, wo du gerade stehst, und gibt
        dir das nötige Handwerkszeug für die Praxis mit.<br /><br />
        Ein besonderer Schwerpunkt liegt auf dem Austausch mit anderen Teilnehmenden: Du bringst dein
        aktuelles Vorgehen mit, gibst und erhältst konkretes Feedback und lernst aus der Praxis
        anderer gemeinnütziger Organisationen. Oft steckt nämlich das meiste Wissen schon in der
        Runde.
      </Blockquote>
    </Fragment>
    <div class="flex rows gap-2" slot="col1">
      <h4>Der Kurs ist für dich, wenn…</h4>
      <Fragment set:html={await KursColumns1.compiledContent()} />
    </div>

    <div class="flex rows gap-2" slot="col2">
      <h4>Im Kurs lernst du…</h4>
      <Fragment set:html={await KursColumns2.compiledContent()} />
    </div>
  </ColumnsSection>

  <section class="prose pt-0">
    <CardPlain>
      <Fragment slot="content">
        <h4 class="kurs-heading">Die Eckdaten</h4>
        <Fragment
          set:html={await KursSchedule.compiledContent().then((content) =>
            content.replace('{period}', phasen.kurse.meta.fokuskurs_kinder_jugend.period)
          )}
        />
      </Fragment>
    </CardPlain>
  </section>

  <section class="prose pt-0">
    <Fragment set:html={await KostenContent.compiledContent()} />
  </section>

  <section class="sticky sticky-bottom">
    <LabLinkButton href="https://pretix.eu/correlaid/fokuskurs-ds/">
      Hier geht es zur Anmeldung!
    </LabLinkButton>
  </section>

  <PeopleSection title="Fragen? Melde dich bei uns!" people={[people.zoe, people.nora]} />

  <div class="flex cols center gap-2 pad-8 wrap" slot="footer-links">
    <LabLinkButton href="/weiterbildungen">CorrelLAB-Weiterbildungen</LabLinkButton>
    <LabLinkButton href="/">Zur Startseite</LabLinkButton>
  </div>
</KursLayout>

<style>
  .kurs-heading {
    margin: 0;
    color: var(--color-grey-900);
    font-weight: var(--font-weight-bold);
  }
</style>
