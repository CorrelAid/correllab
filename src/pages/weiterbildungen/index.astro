---
import { getImage } from "astro:assets";

import Blockquote from "@/components/Blockquote.astro";
import LabLinkButton from "@components/LabLinkButton.astro";
import BackgroundSection from "@components/sections/BackgroundSection.astro";
import ColumnsSection from "@components/sections/ColumnsSection.astro";
import Persona from "@components/Persona.astro";
import Banner from "@compositions/Banner.astro";
import KursLayout from "@layouts/KursLayout.astro";

import carouselBackgroundSvg from "@assets/branding/agentur/CL-Zitat-BackgroundGradient-.svg";
const CarouselBackground = await getImage({
  src: carouselBackgroundSvg,
  format: "webp",
});

import { people } from "@data/people";

import * as AboForYou from "@content/kurse/abo_for_you.md";
import HoneycombGrid from "@components/svelte/HoneycombGrid.svelte";

---

<KursLayout title="CorrelLAB-Weiterbildungen">
  <Fragment slot="subtitle">
    <strong>CorrelLAB-Weiterbildungen</strong>
  </Fragment>
  <p slot="teaser">
    Deine Organisation will Wissen und Kompetenzen aufbauen, um
    Organisationsstrukturen und -prozesse zu verbessern und nachhaltig zu
    verankern? Dann seid ihr hier genau richtig!
  </p>
  <Fragment slot="cta">
    <LabLinkButton href="#start">Übersicht</LabLinkButton>
    <LabLinkButton href="/">Zur Startseite</LabLinkButton>
  </Fragment>

  <ColumnsSection >
    <Fragment slot="pre">
      <Blockquote bare wide>
        Wir bieten zahlreiche Weiterbildungsmöglichkeiten an. Von eintägigen bis zweitägigen Deep Dives über ein- bis sechswöchige Fokuskurse bis hin zum zwölfwöchigen Grundkurs ist alles dabei. Alle Weiterbildungen können einzeln oder im Rahmen des <a class="invert" href="/weiterbildungen/#bildungsabo">Bildungsabo</a> gebucht werden.
      </Blockquote>
      <!-- <h4>Unsere Weiterbildungen:</h4> -->
    </Fragment>

    <div>
      <HoneycombGrid 
        client:idle
        items={[
          { title: "CorrelLAB-<br>Grundkurs", href: "/weiterbildungen/grundkurs/" },
          { title: "Fokuskurs:<br>Kommunizieren mit Daten", href: "/weiterbildungen/fokuskurs-kommunizieren/" },
          { title: "Fokuskurs:<br>Datenerhebung mit Kindern und Jugendlichen", href: "/weiterbildungen/fokuskurs-kinder-jugend/" },
          { title: "Deep Dive:<br>Künstliche Intelligenz", href: "/weiterbildungen/deepdive-ki/" },
          { title: "Deep Dive:<br>Umfragen richtig konzipieren und durchführen", href: "/weiterbildungen/deepdive-umfragen/" },
          { title: "Summer School:<br>Rein in die digitale Welt", href: "/weiterbildungen/summerschool-digitale-welt/" },
          { title: "Summer School:<br>Raus aus dem Datenchaos", href: "/weiterbildungen/summerschool-raus-datenchaos/" }
        ]} 
      />
    </div>
  </ColumnsSection>
  <ColumnsSection glue no_padding_top>
    <div class="flex rows gap-2" slot="col1">
      <h4 id="bildungsabo">Das CorrelLAB-Bildungsabo</h4>
      <p>
        Das CorrelLAB-Bildungsabo ist dein Schlüssel zu einem Jahr voller
        Lernmöglichkeiten – ohne zusätzliche Kosten pro Kurs. Für einen
        Festpreis von 3.200 EUR erhältst du uneingeschränkten Zugang zu unserem
        gesamten Weiterbildungsangebot. Ob du deine Skills systematisch ausbauen
        oder gezielt Lücken schließen möchtest – das Abo gibt dir die Freiheit,
        individuell zu lernen, Kosten zu sparen und praktisches Wissen direkt
        anzuwenden.
      </p>
      <p>
        Das CorrelLAB-Bildungsabo kannst du direkt bei dem Workshop- oder Kursangebot buchen, mit dem du einsteigst. 
      </p>
    </div>
    <div class="flex rows gap-2" slot="col2">
      <h4>Das Abo ist für dich, wenn…</h4>
      <Fragment set:html={await AboForYou.compiledContent()} />
    </div>
  </ColumnsSection>
  <BackgroundSection
    options={{ content_grid: true, center: true }}
    asset={{ src: CarouselBackground.src, position: "bottom right" }}
  >
    <Blockquote>
      <Fragment>
        Wir merken in unserer Arbeit, dass viele Organisationen und Vereine mit
        denselben Herausforderungen kämpfen. Fängt man an, seinen Datenschutz
        oder seine Datenvisualisierungen anzugehen, merkt man schnell, dass es
        am Datenmanagement oder der Dateninfrastruktur hakt. Das
        CorrelLAB-Bildungsabo soll genau das abfangen: 1 Jahr, 1 Preis, alle
        Kurse – damit nichts liegen bleibt.
      </Fragment>
      <Fragment slot="cite">
        <span class="name txt-italic">Nora Cremille &amp; Zoé Wolter</span>
        <span class="role">CorrelAid Bildung</span>
      </Fragment>
    </Blockquote>
  </BackgroundSection>

  <ColumnsSection center_title glue>
    <h2 slot="title">Fragen? Melde dich bei uns!</h2>
    <Persona
      name={people.zoe.name}
      role={people.zoe.role}
      image={people.zoe.image}
      email={people.zoe.email}
      slot="col1"
    />
    <Persona
      name={people.nora.name}
      role={people.nora.role}
      image={people.nora.image}
      email={people.nora.email}
      slot="col2"
    />
  </ColumnsSection>

  <div class="flex cols center gap-2 pad-8 wrap" slot="footer-links">
    <LabLinkButton href="/">Zur Startseite</LabLinkButton>
    <LabLinkButton href="/praxisphase/">Zur Praxisphase</LabLinkButton>
  </div>
</KursLayout>

<style>
  .abo-cta {
    margin-top: calc(var(--padding) * 2);
  }

  .course-sections {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .course-section-heading {
    margin: 0 0 0.5rem;
    color: var(--color-lab-blue-dark);
  }

  .course-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .abo-note {
    font-size: var(--font-size-sm);
    color: var(--color-gray-700, #555);
    margin-top: 0.5rem;
  }
</style>
