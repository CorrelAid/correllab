---
import { getImage } from "astro:assets";

import Blockquote from "@/components/Blockquote.astro";
import CardPlain from "@components/cards/CardPlain.astro";
import LabLinkButton from "@components/LabLinkButton.astro";
import BackgroundSection from "@components/sections/BackgroundSection.astro";
import ColumnsSection from "@components/sections/ColumnsSection.astro";
import PeopleSection from "@compositions/People.astro";
import KursLayout from "@layouts/KursLayout.astro";

import carouselBackgroundSvg from "@assets/branding/agentur/CL-Zitat-BackgroundGradient-.svg";
const CarouselBackground = await getImage({
    src: carouselBackgroundSvg,
    format: "webp",
});

import phasen from "@data/phasen.json";
import { quotes } from "@data/quotes.js";
import { people } from "@data/people";

import * as KursColumns1 from "@content/kurse/summerschool_digitale_welt_columns_1.md";
import * as KursColumns2 from "@content/kurse/summerschool_digitale_welt_columns_2.md";

import * as KursSchedule from "@content/kurse/summerschool_digitale_welt_schedule.md";
import * as KostenContent from "@content/kurse/summerschool_digitale_welt_kosten.md";
---

<KursLayout title="CorrelLAB - Summer School: Rein in die digitale Welt">
    <Fragment slot="subtitle">
        Summer School<br />&ndash;&nbsp;<strong
            >Rein in die digitale Welt</strong
        >
    </Fragment>
    <p slot="teaser">
        Du willst eure Arbeit auf das nächste Level bringen, indem du Dinge in
        deinem Verein oder deiner Initiative digitalisiert? Unsere Summer School
        holt dich da ab, wo du gerade stehst, damit du sicher und selbstbewusst
        mit digitaler Datenablage, Datenschutz und Kommunikation umgehen kannst.
    </p>
    <Fragment slot="cta">
        <LabLinkButton href="#start">Kursüberblick</LabLinkButton>
        <LabLinkButton href="/weiterbildungen"
            >CorrelLAB-Weiterbildungen</LabLinkButton
        >
    </Fragment>

    <ColumnsSection center_title>
        <Fragment slot="pre">
            <Blockquote bare wide>
                Die Welt wird immer digitaler und das ist eine Chance für deinen
                Verein! Doch der Einstieg ins Digitale kann herausfordernd sein:
                Wie behält man den Überblick über wichtige Informationen? Was
                muss man bei Datenschutz und DSGVO beachten? Und wie gelingt die
                Kommunikation mit den Mitgliedern auch online? Genau hier setzt
                unsere „CorrelLAB-Summer-School: Rein in die digitale Welt!“ an!
                <br/>
                <br/>
                In drei abwechslungsreichen Online-Abend-Terminen begleiten wir
                dich Schritt für Schritt in die digitale Welt. Gemeinsam
                erarbeiten wir Lösungen, die zu deinem Verein passen, ohne
                komplizierte Fachsprache, mit viel Praxisbezug.
            </Blockquote>
        </Fragment>
        <div class="flex rows gap-2" slot="col1">
            <h4>Der Kurs ist für dich, wenn…</h4>
            <Fragment set:html={await KursColumns1.compiledContent()} />
        </div>

        <div class="flex rows gap-2" slot="col2">
            <h4>Im Kurs lernst du…</h4>
            <Fragment set:html={await KursColumns2.compiledContent()} />
        </div>
    </ColumnsSection>

    <section class="prose pt-0">
        <CardPlain>
            <Fragment slot="content">
                <h4 class="kurs-heading">Die Eckdaten</h4>
                <Fragment
                    set:html={await KursSchedule.compiledContent()}
                />
            </Fragment>
        </CardPlain>
    </section>

    <section class="prose pt-0">
        <Fragment set:html={await KostenContent.compiledContent()} />
    </section>

    <section class="sticky sticky-bottom">
        <LabLinkButton href=" https://pretix.eu/correlaid/summer-school/4925698/">
            Hier geht es zur Anmeldung!
        </LabLinkButton>
    </section>

    <PeopleSection
        title="Fragen? Melde dich bei uns!"
        people={[people.zoe, people.nora]}
    />

    <div class="flex cols center gap-2 pad-8 wrap" slot="footer-links">
        <LabLinkButton href="/weiterbildungen"
            >CorrelLAB-Weiterbildungen</LabLinkButton
        >
        <LabLinkButton href="/">Zur Startseite</LabLinkButton>
    </div>
</KursLayout>

<style>
    .kurs-heading {
        margin: 0;
        color: var(--color-grey-900);
        font-weight: var(--font-weight-bold);
    }
</style>
