---
import { getImage } from "astro:assets";

import Blockquote from "@/components/Blockquote.astro";
import CardPlain from "@components/cards/CardPlain.astro";
import LabLinkButton from "@components/LabLinkButton.astro";
import BackgroundSection from "@components/sections/BackgroundSection.astro";
import ColumnsSection from "@components/sections/ColumnsSection.astro";
import PeopleSection from "@compositions/People.astro";
import KursLayout from "@layouts/KursLayout.astro";

import carouselBackgroundSvg from "@assets/branding/agentur/CL-Zitat-BackgroundGradient-.svg";
const CarouselBackground = await getImage({
    src: carouselBackgroundSvg,
    format: "webp",
});

import phasen from "@data/phasen.json";
import { quotes } from "@data/quotes.js";
import { people } from "@data/people";

import * as KursColumns1 from "@content/kurse/summerschool_raus_datenchaos_columns_1.md";
import * as KursColumns2 from "@content/kurse/summerschool_raus_datenchaos_columns_2.md";

import * as KursSchedule from "@content/kurse/summerschool_raus_datenchaos_schedule.md";
import * as KostenContent from "@content/kurse/summerschool_raus_datenchaos_kosten.md";
---

<KursLayout title="CorrelLAB - Summer School: Raus aus dem Datenchaos">
    <Fragment slot="subtitle">
        Summer School<br />&ndash;&nbsp;<strong>Raus aus dem Datenchaos</strong>
    </Fragment>
    <p slot="teaser">
        Du willst eure Arbeit auf das nächste Level bringen, indem du euer
        Datenmanagement strukturierst und eure Datensätze bereinigst? Unsere
        Summer School holt dich da ab, wo du gerade stehst, damit du immer das
        wiederfindest, was du brauchst.
    </p>
    <Fragment slot="cta">
        <LabLinkButton href="#start">Kursüberblick</LabLinkButton>
        <LabLinkButton href="/weiterbildungen"
            >CorrelLAB-Weiterbildungen</LabLinkButton
        >
    </Fragment>

    <ColumnsSection center_title>
        <Fragment slot="pre">
            <Blockquote bare wide>
                Daten sind überall, aber nie dort, wo du sie erwartest?
                Informationen sind doppelt, unstrukturiert oder schwer
                auffindbar? Dann ist unsere „CorrelLAB-Summer-School: Raus aus
                dem Datenchaos“ genau das Richtige für dich!
            </br>
            </br>
                In vier
                praxisorientierten Terminen zeigen wir dir, wie du aus dem
                Datenchaos klare, nutzbare Strukturen schaffst. Lerne, wie du
                eure Daten effizient organisieren, Workflows optimieren und den
                Grundstein für eine zukunftsfähige Dateninfrastruktur legen
                kannst.
            </Blockquote>
        </Fragment>
        <div class="flex rows gap-2" slot="col1">
            <h4>Der Kurs ist für dich, wenn…</h4>
            <Fragment set:html={await KursColumns1.compiledContent()} />
        </div>

        <div class="flex rows gap-2" slot="col2">
            <h4>Im Kurs lernst du…</h4>
            <Fragment set:html={await KursColumns2.compiledContent()} />
        </div>
    </ColumnsSection>

    <section class="prose pt-0">
        <CardPlain>
            <Fragment slot="content">
                <h4 class="kurs-heading">Die Eckdaten</h4>
                <Fragment set:html={await KursSchedule.compiledContent()} />
            </Fragment>
        </CardPlain>
    </section>

    <section class="prose pt-0">
        <Fragment set:html={await KostenContent.compiledContent()} />
    </section>

    <section class="sticky sticky-bottom">
        <LabLinkButton
            href="https://pretix.eu/correlaid/summer-school/4925701/"
        >
            Hier geht es zur Anmeldung!
        </LabLinkButton>
    </section>

    <PeopleSection
        title="Fragen? Melde dich bei uns!"
        people={[people.zoe, people.nora]}
    />

    <div class="flex cols center gap-2 pad-8 wrap" slot="footer-links">
        <LabLinkButton href="/weiterbildungen"
            >CorrelLAB-Weiterbildungen</LabLinkButton
        >
        <LabLinkButton href="/">Zur Startseite</LabLinkButton>
    </div>
</KursLayout>

<style>
    .kurs-heading {
        margin: 0;
        color: var(--color-grey-900);
        font-weight: var(--font-weight-bold);
    }
</style>
